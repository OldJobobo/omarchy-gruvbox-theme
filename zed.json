{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Gruvbox Material",
  "author": "omarchy-gruvbox-theme",
  "themes": [
    {
      "name": "Gruvbox Material Dark",
      "appearance": "dark",
      "style": {
        "background":        "#282828",
        "editor.background": "#282828",
        "editor.foreground": "#d4be98",
        "text":              "#d4be98",
        "text.muted":        "#928374",
        "text.placeholder":  "#92837480",
        "text.disabled":     "#92837460",
        "text.accent":       "#7daea3",

        "surface.background":   "#32302f",
        "element.background":   "#3c3836",
        "element.hover":        "rgba(80,73,69,0.4)",
        "element.selected":     "rgba(125,174,163,0.15)",
        "element.active":       "rgba(125,174,163,0.25)",
        "element.disabled":     "rgba(212,190,152,0.1)",
        "ghost_element.hover":  "rgba(146,131,116,0.2)",
        "ghost_element.selected": "rgba(146,131,116,0.25)",
        "ghost_element.active": "rgba(146,131,116,0.35)",

        "border":              "#45403d",
        "border.variant":      "#3c3836",
        "border.focused":      "#7daea3",
        "border.selected":     "#7daea3",
        "border.transparent":  "transparent",
        "border.disabled":     "#3c3836",

        "elevated_surface.background": "#3c3836",
        "panel.background":            "#32302f",
        "title_bar.background":        "#32302f",
        "title_bar.inactive_background": "#282828",
        "toolbar.background":          "#32302f",
        "tab_bar.background":          "#282828",
        "tab.inactive_background":     "#282828",
        "tab.active_background":       "#32302f",
        "status_bar.background":       "#282828",
        "drop_target.background":      "rgba(125,174,163,0.15)",

        "scrollbar.track.background": "transparent",
        "scrollbar.track.border":     "#3c3836",
        "scrollbar.thumb.background": "#504945",
        "scrollbar.thumb.border":     "transparent",
        "scrollbar.thumb.hover_background": "#928374",

        "editor.gutter.background":       "#282828",
        "editor.active_line.background":  "rgba(146,131,116,0.08)",
        "editor.highlighted_line.background": "rgba(146,131,116,0.06)",
        "editor.line_number":             "#504945",
        "editor.active_line_number":      "#928374",
        "editor.invisible":               "#45403d",
        "editor.wrap_guide":              "#3c3836",
        "editor.active_wrap_guide":       "#45403d",
        "editor.document_highlight.read_background":  "rgba(125,174,163,0.12)",
        "editor.document_highlight.write_background": "rgba(125,174,163,0.20)",

        "terminal.background":        "#282828",
        "terminal.foreground":        "#d4be98",
        "terminal.dim_foreground":    "#928374",
        "terminal.bright_foreground": "#e2cca9",
        "terminal.ansi.black":        "#3c3836",
        "terminal.ansi.red":          "#ea6962",
        "terminal.ansi.green":        "#a9b665",
        "terminal.ansi.yellow":       "#d8a657",
        "terminal.ansi.blue":         "#7daea3",
        "terminal.ansi.magenta":      "#d3869b",
        "terminal.ansi.cyan":         "#89b482",
        "terminal.ansi.white":        "#d4be98",
        "terminal.ansi.bright_black": "#928374",
        "terminal.ansi.bright_red":   "#ea6962",
        "terminal.ansi.bright_green": "#a9b665",
        "terminal.ansi.bright_yellow": "#d8a657",
        "terminal.ansi.bright_blue":  "#7daea3",
        "terminal.ansi.bright_magenta": "#d3869b",
        "terminal.ansi.bright_cyan":  "#89b482",
        "terminal.ansi.bright_white": "#e2cca9",

        "link_text.hover": "#8dbdb2",

        "conflict":         "#d8a657",
        "conflict.background": "rgba(216,166,87,0.1)",
        "conflict.border":  "#d8a657",
        "created":          "#a9b665",
        "created.background": "rgba(169,182,101,0.1)",
        "created.border":   "#a9b665",
        "deleted":          "#ea6962",
        "deleted.background": "rgba(234,105,98,0.1)",
        "deleted.border":   "#ea6962",
        "modified":         "#d8a657",
        "modified.background": "rgba(216,166,87,0.08)",
        "modified.border":  "#d8a657",
        "renamed":          "#7daea3",
        "renamed.background": "rgba(125,174,163,0.1)",
        "renamed.border":   "#7daea3",
        "ignored":          "#928374",
        "ignored.background": "transparent",
        "ignored.border":   "transparent",
        "hint":             "#928374",
        "hint.background":  "transparent",
        "hint.border":      "#45403d",
        "info":             "#7daea3",
        "info.background":  "rgba(125,174,163,0.1)",
        "info.border":      "#7daea3",
        "warning":          "#d8a657",
        "warning.background": "rgba(216,166,87,0.1)",
        "warning.border":   "#d8a657",
        "error":            "#ea6962",
        "error.background": "rgba(234,105,98,0.1)",
        "error.border":     "#ea6962",
        "success":          "#a9b665",
        "success.background": "rgba(169,182,101,0.1)",
        "success.border":   "#a9b665",
        "unreachable":      "#928374",
        "unreachable.background": "transparent",
        "unreachable.border": "#45403d",

        "players": [
          {
            "cursor":     "#d4be98",
            "background": "#3c3836",
            "selection":  "rgba(212,190,152,0.15)"
          },
          {
            "cursor":     "#7daea3",
            "background": "#7daea3",
            "selection":  "rgba(125,174,163,0.2)"
          },
          {
            "cursor":     "#a9b665",
            "background": "#a9b665",
            "selection":  "rgba(169,182,101,0.2)"
          },
          {
            "cursor":     "#d3869b",
            "background": "#d3869b",
            "selection":  "rgba(211,134,155,0.2)"
          }
        ],

        "syntax": {
          "attribute":    { "color": "#7daea3" },
          "boolean":      { "color": "#d8a657" },
          "comment":      { "color": "#928374", "font_style": "italic" },
          "comment.doc":  { "color": "#928374", "font_style": "italic" },
          "constant":     { "color": "#d8a657" },
          "constructor":  { "color": "#89b482" },
          "embedded":     { "color": "#d4be98" },
          "emphasis":     { "color": "#d4be98", "font_style": "italic" },
          "emphasis.strong": { "color": "#d4be98", "font_weight": 700 },
          "enum":         { "color": "#d8a657" },
          "function":     { "color": "#a9b665" },
          "function.builtin": { "color": "#e78a4e" },
          "function.method": { "color": "#89b482" },
          "hint":         { "color": "#928374" },
          "keyword":      { "color": "#ea6962" },
          "keyword.operator": { "color": "#7daea3" },
          "label":        { "color": "#d8a657" },
          "link_text":    { "color": "#7daea3", "font_style": "italic" },
          "link_uri":     { "color": "#89b482" },
          "number":       { "color": "#d8a657" },
          "operator":     { "color": "#7daea3" },
          "predictive":   { "color": "#928374", "font_style": "italic" },
          "preproc":      { "color": "#ea6962" },
          "primary":      { "color": "#d4be98" },
          "property":     { "color": "#7daea3" },
          "punctuation":  { "color": "#928374" },
          "punctuation.bracket": { "color": "#d4be98" },
          "punctuation.delimiter": { "color": "#928374" },
          "punctuation.list_marker": { "color": "#e78a4e" },
          "punctuation.special": { "color": "#89b482" },
          "string":       { "color": "#a9b665" },
          "string.escape": { "color": "#89b482" },
          "string.regex": { "color": "#89b482" },
          "string.special": { "color": "#89b482" },
          "string.special.symbol": { "color": "#d3869b" },
          "tag":          { "color": "#ea6962" },
          "text.literal": { "color": "#a9b665" },
          "title":        { "color": "#d8a657", "font_weight": 700 },
          "type":         { "color": "#d8a657" },
          "type.builtin": { "color": "#e78a4e" },
          "variable":     { "color": "#d4be98" },
          "variable.builtin": { "color": "#e78a4e" },
          "variable.member": { "color": "#d4be98" },
          "variable.parameter": { "color": "#d3869b" },
          "variant":      { "color": "#d8a657" }
        }
      }
    }
  ]
}
